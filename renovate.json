{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":automergeDigest",
    ":skipStatusChecks",
    ":semanticCommits",
    ":dependencyDashboard",
    ":assignee(AlessandroZanatta)",
    ":disableRateLimiting",
    ":automergeBranch",
    ":timezone(Europe/Rome)",

    "github>alessandrozanatta/homelab-v2//.renovate/datasources.json",
    "github>alessandrozanatta/homelab-v2//.renovate/labels.json",
    "github>alessandrozanatta/homelab-v2//.renovate/managers.json",
    "github>alessandrozanatta/homelab-v2//.renovate/rules.json"
  ],
  "argocd": { "managerFilePatterns": ["apps/**/*.yaml"] },
  "kubernetes": {
    "managerFilePatterns": ["kubernetes/**/*.yaml", "helm/**/extra/**/*.yaml"]
  },
  "dependencyDashboardTitle": "Renovate Dashboard 🤖"
}
